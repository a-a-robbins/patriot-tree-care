# Copy to server/.env and fill in values

# SendGrid: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx

# Verified sender in SendGrid (Single Sender or domain authentication)
QUOTE_FROM_EMAIL=quotes@yourdomain.com

# Where quote form submissions are delivered
QUOTE_TO_EMAIL=owner@yourdomain.com

# Optional
SITE_NAME=Patriot Tree Care
PORT=3001
# Comma-separated allowed origins in production, e.g. https://patriottreecare.com
# CORS_ORIGIN=https://patriottreecare.com
